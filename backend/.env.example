# Copie para .env e preencha com seus dados reais
# NUNCA versione o .env com dados reais no Git!

# Connection string do Supabase (Settings → Database → URI)
DB_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-ID].supabase.co:5432/postgres

# Porta do servidor backend
PORT=3001

# URL do frontend em produção (Vercel/Netlify) — deixe vazio localmente
CORS_ORIGIN=https://SEU-SITE.vercel.app
